@using System.Web.Mvc.Html
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Sistema de Tickets</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            background-color: #f7f9fc;
        }

        /* Estilo da Barra Lateral Azul */
        .sidebar {
            width: 250px;
            min-height: 100vh;
            background-color: #0b1a50;
            color: white;
            padding: 20px 0;
            display: flex;
            flex-direction: column;
            position: fixed;
            z-index: 1000;
        }

        /* Título do Sistema */
        .sidebar-header {
            padding: 0 20px 20px 20px;
            font-size: 20px;
            font-weight: bold;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 20px;
        }

        /* Informações do Usuário */
        .user-info {
            padding: 0 20px 20px 20px;
            display: flex;
            align-items: center;
        }

            .user-info i {
                color: #3b82f6;
                font-size: 24px;
                margin-right: 10px;
            }

        .user-name {
            font-weight: bold;
            font-size: 16px;
        }

        .user-role {
            font-size: 13px;
            color: #ccc;
        }

        /* Estilo dos Links de Navegação */
        .sidebar-menu a {
            padding: 15px 20px;
            display: block;
            color: white;
            text-decoration: none;
            font-size: 16px;
            border-left: 5px solid transparent;
        }

            .sidebar-menu a:hover {
                background-color: rgba(255, 255, 255, 0.1);
                color: white;
            }

            .sidebar-menu a.active {
                background-color: #3b82f6;
                border-left-color: #3b82f6;
            }

        /* Botão Sair no Rodapé */
        .sidebar-footer {
            margin-top: auto;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            background-color: rgba(255, 255, 255, 0.1);
        }

        /* Conteúdo Principal (à direita da sidebar) */
        .main-content {
            margin-left: 250px;
            flex-grow: 1;
            padding: 30px;
            width: calc(100% - 250px);
        }

        .content-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 15px;
            border-bottom: 1px solid #ddd;
            margin-bottom: 20px;
        }

        /* Badge de perfil no canto superior direito */
        .profile-badge {
            position: fixed;
            top: 20px;
            right: 20px;
            background-color: #dc2626;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
            font-size: 14px;
            z-index: 9999;
        }
    </style>
</head>
<body>

    <div class="sidebar">

        <div class="sidebar-header">
            Sistema de Tickets
        </div>

        <div class="user-info">
            <i class="fas fa-user-circle"></i>
            <div>
                <div class="user-name">@ViewBag.UserName</div>
                <div class="user-role">@ViewBag.UserProfile</div>
            </div>
        </div>

        <div class="sidebar-menu">

            <a href="@Url.Action("Dashboard", "Home")" class="@(ViewBag.Title == "Dashboard" ? "active" : "")">
                <i class="fas fa-home mr-2"></i> Dashboard
            </a>

            @if (ViewBag.UserProfile == "Colaborador")
            {
                <a href="@Url.Action("NovoTicket", "Home")" class="@(ViewBag.Title == "Novo Ticket" ? "active" : "")">
                    <i class="fas fa-plus-square mr-2"></i> Novo Ticket
                </a>
                <a href="@Url.Action("MeusTickets", "Home")" class="@(ViewBag.Title == "Meus Tickets" ? "active" : "")">
                    <i class="fas fa-list-alt mr-2"></i> Meus Tickets
                </a>
            }
            else if (ViewBag.UserProfile == "Administrador")
            {
                <a href="@Url.Action("TodosTickets", "Home")" class="@(ViewBag.Title == "Todos os Tickets" ? "active" : "")">
                    <i class="fas fa-clipboard-list mr-2"></i> Todos os Tickets
                </a>
                <a href="@Url.Action("Administracao", "Home")" class="@(ViewBag.Title == "Administração" ? "active" : "")">
                    <i class="fas fa-user-cog mr-2"></i> Administração
                </a>
            }
        </div>

        <div class="sidebar-footer">
            <a href="@Url.Action("Logout", "Home")" class="text-light" style="padding: 15px 20px; display: block;">
                <i class="fas fa-sign-out-alt mr-2"></i> Sair
            </a>
        </div>
    </div>

    <!-- Badge de perfil fixo no canto superior direito -->
    <div class="profile-badge">
        Perfil: @ViewBag.UserProfile<br>
        UserName: @ViewBag.UserName
    </div>

    <div class="main-content">
        <div class="content-header">
            <h4>@ViewBag.Title</h4>
        </div>

        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>