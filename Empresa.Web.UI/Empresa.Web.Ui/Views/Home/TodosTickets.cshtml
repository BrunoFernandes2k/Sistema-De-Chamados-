@using Empresa.Web.Ui.DTOs
@model IEnumerable<TicketListDTO>

@{
    ViewBag.Title = "Todos os Tickets";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Container principal (Card Branco) */
    .container-moderno {
        background-color: white;
        padding: 35px;
        border-radius: 20px; /* Bordas mais arredondadas */
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
        margin-top: 20px;
        margin-bottom: 30px;
    }

    /* --- BOTÕES MODERNOS --- */
    .btn-moderno {
        border: none;
        border-radius: 10px;
        padding: 12px 25px;
        font-weight: bold;
        font-size: 15px;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none !important;
    }

    .btn-moderno-primary {
        background-color: #6366f1;
        color: white !important;
    }

        .btn-moderno-primary:hover {
            background-color: #4f46e5;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99, 102, 241, 0.4);
        }

    .btn-moderno-secondary {
        background-color: #f1f5f9;
        color: #475569 !important;
    }

        .btn-moderno-secondary:hover {
            background-color: #e2e8f0;
            color: #1e293b !important;
        }

    /* --- ESTILO DOS MODAIS (O PONTO DA SETA) --- */
    .modal-content {
        border: none;
        border-radius: 20px !important; /* Arredondamento igual ao card principal */
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .modal-header {
        background-color: #1e1b4b; /* Azul marinho profundo para Admin */
        color: white;
        border-bottom: none;
        padding: 20px 30px;
    }

    .modal-title {
        font-weight: 800;
        letter-spacing: 0.5px;
    }

    .modal-body {
        padding: 30px;
        background-color: #ffffff;
    }

    .modal-footer {
        border-top: 1px solid #f1f5f9;
        padding: 20px 30px;
        background-color: #f8fafc;
    }

    /* Estilo do Select e Inputs dentro do Modal */
    .form-control-moderno {
        height: auto;
        padding: 12px 15px;
        border-radius: 10px;
        border: 2px solid #e2e8f0;
        font-weight: 500;
        transition: all 0.2s;
    }

        .form-control-moderno:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            outline: none;
        }

    /* --- ESTILO DA TABELA --- */
    .table-moderna thead th {
        background-color: #f8fafc;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        border-top: none;
        padding: 18px;
    }

    .table-moderna td {
        padding: 18px;
        vertical-align: middle;
        border-top: 1px solid #f1f5f9;
    }

    .action-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px; /* Ícones agora são quadrados arredondados */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        border: none;
        color: white;
    }
</style>

<div class="container-fluid">
    <div class="container-moderno">

        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 style="color: #1e1b4b; font-weight: 800; margin: 0; font-size: 2rem;">
                    Gestão Geral de Tickets
                </h2>
                <p class="text-muted mb-0">Painel de controle administrativo de chamados</p>
            </div>
            <div class="d-flex">
                <a href="@Url.Action("Dashboard", "Home")" class="btn-moderno btn-moderno-secondary mr-3">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
                <button onclick="location.reload()" class="btn-moderno btn-moderno-primary" style="background-color: #10b981;">
                    <i class="fas fa-sync-alt"></i> Atualizar
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-moderna mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Assunto</th>
                        <th>Usuário</th>
                        <th>Status</th>
                        <th>Prioridade</th>
                        <th>Abertura</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var ticket in Model)
                        {
                            <tr id="ticket-@ticket.Id">
                                <td class="font-weight-bold" style="color: #6366f1;">#@ticket.Id</td>
                                <td>
                                    <a href="javascript:void(0)" onclick="verDetalhes(@ticket.Id)" class="font-weight-bold text-dark">
                                        @ticket.Assunto
                                    </a>
                                </td>
                                <td><span class="text-muted"><i class="fas fa-user-circle mr-2"></i>@ticket.NomeUsuario</span></td>
                                <td>
                                    @if (ticket.Status == "Aberto")
                                    {<span class="badge badge-success p-2">Aberto</span> }
                                    else if (ticket.Status == "Em Andamento")
                                    { <span class="badge badge-warning p-2 text-white">Andamento</span> }
                                    else
                                    { <span class="badge badge-secondary p-2">Concluído</span>}
                                </td>
                                <td>
                                    @if (ticket.Prioridade == "Baixa")
                                    {<span class="text-info font-weight-bold">● Baixa</span> }
                                    else if (ticket.Prioridade == "Media" || ticket.Prioridade == "Média")
                                    { <span class="text-warning font-weight-bold">● Média</span> }
                                    else
                                    { <span class="text-danger font-weight-bold">● Alta</span>}
                                </td>
                                <td class="small text-muted">@ticket.DataAbertura.ToString("dd/MM/yy HH:mm")</td>
                                <td class="text-center">
                                    <button onclick="verDetalhes(@ticket.Id)" class="action-icon bg-info" title="Detalhes"><i class="fas fa-eye"></i></button>
                                    <button onclick="alterarStatus(@ticket.Id, '@ticket.Status')" class="action-icon bg-warning mx-1" title="Status"><i class="fas fa-edit text-white"></i></button>
                                    <button onclick="deletarTicket(@ticket.Id)" class="action-icon bg-danger" title="Excluir"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalStatus" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-exchange-alt mr-2"></i> Atualizar Status</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="ticketId" />
                <div class="form-group mb-0">
                    <label class="font-weight-bold text-muted small mb-2">SELECIONE A NOVA ETAPA DO TICKET:</label>
                    <select id="novoStatus" class="form-control form-control-moderno">
                        <option value="Aberto">Aberto</option>
                        <option value="Em Andamento">Em Andamento</option>
                        <option value="Concluido">Concluído</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-link text-muted font-weight-bold" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn-moderno btn-moderno-primary" onclick="salvarStatus()">
                    <i class="fas fa-save"></i> Gravar Alteração
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalDetalhes" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-info-circle mr-2"></i> Detalhes do Chamado</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="row mb-4">
                    <div class="col-6">
                        <span class="text-muted small font-weight-bold d-block">ID TICKET</span>
                        <span id="detalhe-id" class="h4 font-weight-bold text-primary"></span>
                    </div>
                    <div class="col-6 text-right" id="detalhe-status"></div>
                </div>
                <div class="bg-light p-3 rounded-lg mb-4">
                    <span class="text-muted small font-weight-bold d-block mb-1">ASSUNTO</span>
                    <div id="detalhe-assunto" class="h6 font-weight-bold mb-0"></div>
                </div>
                <span class="text-muted small font-weight-bold d-block mb-2">DESCRIÇÃO DETALHADA</span>
                <div id="detalhe-descricao" class="p-3 border rounded-lg" style="background: #fff; min-height: 120px;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-moderno btn-moderno-secondary" data-dismiss="modal">Fechar</button>
                <button type="button" class="btn-moderno btn-moderno-primary" style="background-color: #f59e0b;" onclick="alterarStatusModal()">
                    <i class="fas fa-edit"></i> Alterar Status
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    var ticketAtual = null;

    function verDetalhes(id) {
        $.ajax({
            url: '@Url.Action("GetTicketDetalhes", "Home")',
            type: 'GET',
            data: { id: id },
            success: function(response) {
                var ticket = response.ticket || response;
                ticketAtual = ticket;
                $('#detalhe-id').text('#' + (ticket.id || ticket.Id));
                $('#detalhe-assunto').text(ticket.assunto || ticket.Assunto);
                $('#detalhe-descricao').text(ticket.descricao || ticket.Descricao);

                var status = ticket.status || ticket.Status;
                var badge = status == 'Aberto' ? 'badge-success' : (status == 'Em Andamento' ? 'badge-warning text-white' : 'badge-secondary');
                $('#detalhe-status').html('<span class="badge '+badge+' p-2">'+status+'</span>');

                $('#modalDetalhes').modal('show');
            }
        });
    }

    function alterarStatusModal() {
        if (ticketAtual) {
            $('#modalDetalhes').modal('hide');
            setTimeout(function() {
                alterarStatus(ticketAtual.id || ticketAtual.Id, ticketAtual.status || ticketAtual.Status);
            }, 300);
        }
    }

    function alterarStatus(id, statusAtual) {
        $('#ticketId').val(id);
        $('#novoStatus').val(statusAtual);
        $('#modalStatus').modal('show');
    }

    function salvarStatus() {
        var id = $('#ticketId').val();
        var status = $('#novoStatus').val();
        $.ajax({
            url: '@Url.Action("AtualizarStatusTicket", "Home")',
            type: 'POST',
            data: { id: parseInt(id), status: status },
            success: function(response) {
                if (response.success) { location.reload(); }
                else { alert(response.message); }
            }
        });
    }

    function deletarTicket(id) {
        if (confirm('Atenção: Esta ação é irreversível. Deseja excluir este ticket?')) {
            $.ajax({
                url: '@Url.Action("DeletarTicket", "Home")',
                type: 'POST',
                data: { id: id },
                success: function(response) {
                    if (response.success) { $('#ticket-' + id).fadeOut(); }
                }
            });
        }
    }
</script>