@using Empresa.Web.Ui.DTOs
@model IEnumerable<TicketListDTO>
@{
    ViewBag.Title = "Meus Tickets";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Estilos globais para a página */
    .container-moderno {
        background-color: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        margin-top: 20px;
        margin-bottom: 20px;
    }

    /* --- ESTILOS DOS BOTÕES MODERNOS --- */
    .btn-moderno {
        border: none;
        border-radius: 8px; /* Bordas arredondadas */
        padding: 10px 20px;
        font-weight: bold;
        font-size: 16px;
        transition: all 0.3s ease; /* Animação suave */
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px; /* Espaço entre o ícone e o texto */
        text-decoration: none !important;
        color: white;
    }

    /* Cor do Botão Principal (Novo Ticket) */
    .btn-moderno-primary {
        background-color: #6366f1; /* Roxo/azul moderno */
    }

        .btn-moderno-primary:hover {
            background-color: #4f46e5;
            transform: translateY(-2px); /* Efeito de pular pra cima */
            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15); /* Aumenta a sombra */
            color: white;
        }

    /* Cor do Botão Secundário (Dashboard) */
    .btn-moderno-secondary {
        background-color: #f1f5f9; /* Cinza bem clarinho */
        color: #475569 !important;
    }

        .btn-moderno-secondary:hover {
            background-color: #e2e8f0;
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
            color: #334155 !important;
        }

    /* Estilo para a tabela dentro do card */
    .table-moderna thead {
        background-color: #f8fafc;
        color: #475569;
        border-bottom: 2px solid #e2e8f0;
    }

    .table-moderna th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table td {
        vertical-align: middle;
    }
</style>

<div class="container-fluid">
    <div class="container-moderno">
        <h2 style="color: #4338ca; margin-bottom: 20px; font-weight: bold;">Meus Tickets</h2>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <a href="@Url.Action("NovoTicket", "Home")" class="btn-moderno btn-moderno-primary">
                <i class="fas fa-plus"></i> Novo Ticket
            </a>
            <a href="@Url.Action("Dashboard", "Home")" class="btn-moderno btn-moderno-secondary">
                <i class="fas fa-arrow-left"></i> Voltar ao Dashboard
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-moderna mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Assunto</th>
                        <th>Status</th>
                        <th>Prioridade</th>
                        <th>Data Abertura</th>
                        <th>Data Fechamento</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var ticket in Model)
                        {
                            <tr>
                                <td><strong>#@ticket.Id</strong></td>
                                <td>@ticket.Assunto</td>
                                <td>
                                    @if (ticket.Status == "Aberto")
                                    {
                                        <span class="badge badge-success px-2 py-1">Aberto</span>
                                    }
                                    else if (ticket.Status == "Em Andamento")
                                    {
                                        <span class="badge badge-warning px-2 py-1">Em Andamento</span>
                                    }
                                    else if (ticket.Status == "Concluido" || ticket.Status == "Concluído")
                                    {
                                        <span class="badge badge-secondary px-2 py-1">Concluído</span>
                                    }
                                </td>
                                <td>
                                    @if (ticket.Prioridade == "Baixa")
                                    {
                                        <span class="badge badge-info px-2 py-1">Baixa</span>
                                    }
                                    else if (ticket.Prioridade == "Media" || ticket.Prioridade == "Média")
                                    {
                                        <span class="badge badge-warning px-2 py-1">Média</span>
                                    }
                                    else if (ticket.Prioridade == "Alta")
                                    {
                                        <span class="badge badge-danger px-2 py-1">Alta</span>
                                    }
                                </td>
                                <td>@ticket.DataAbertura.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (ticket.DataFechamento.HasValue)
                                    {
                                        <span class="text-success font-weight-bold">
                                            <i class="fas fa-check-circle"></i>
                                            @ticket.DataFechamento.Value.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            <i class="fas fa-clock"></i> Em andamento
                                        </span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-danger rounded-circle p-2" onclick="deletarTicket(@ticket.Id)" title="Deletar Ticket">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Você ainda não tem tickets.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function deletarTicket(id) {
        if (confirm('Tem certeza que deseja deletar este ticket?')) {
            $.ajax({
                url: '@Url.Action("DeletarTicket", "Home")',
                type: 'POST',
                data: { id: id },
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert('Erro: ' + response.message);
                    }
                },
                error: function () {
                    alert('Erro ao deletar ticket.');
                }
            });
        }
    }
</script>