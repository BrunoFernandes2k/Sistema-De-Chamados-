@using System.Web.Mvc.Html
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - TechFlow Solutions</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            background-color: #6366f1; /* Fundo do sistema inteiro */
        }

        /* --- ESTILO NOVO DA BARRA LATERAL --- */
        .sidebar {
            width: 260px;
            min-height: 100vh;
            background-color: #1e1b4b; /* Um tom super escuro e elegante para o menu */
            color: white;
            padding: 20px 0;
            display: flex;
            flex-direction: column;
            position: fixed;
            z-index: 1000;
            box-shadow: 4px 0 15px rgba(0,0,0,0.15); /* Sombra suave separando do conteúdo */
        }

        .sidebar-header {
            padding: 0 20px 20px 20px;
            font-size: 22px;
            font-weight: 800;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            margin-bottom: 20px;
            color: white;
            letter-spacing: 0.5px;
        }

        .user-info {
            padding: 0 20px 20px 20px;
            display: flex;
            align-items: center;
        }

            .user-info i {
                color: #6366f1; /* Ícone com a cor principal */
                font-size: 36px; /* Ícone um pouco maior */
                margin-right: 15px;
            }

        .user-name {
            font-weight: bold;
            font-size: 16px;
            color: white;
        }

        .user-role {
            font-size: 13px;
            color: #94a3b8; /* Cor um pouco mais suave para o cargo */
        }

        /* Menu Links Modernizados (Formato Pill) */
        .sidebar-menu {
            display: flex;
            flex-direction: column;
            gap: 5px; /* Espaço entre os botões */
        }

            .sidebar-menu a {
                padding: 12px 20px;
                margin: 0 15px; /* Descola o botão das beiradas da barra */
                display: block;
                color: #cbd5e1;
                text-decoration: none;
                font-size: 15px;
                border-radius: 10px; /* Bordas bem arredondadas */
                transition: all 0.3s ease; /* Animação suave */
            }

                .sidebar-menu a i {
                    width: 25px; /* Alinha os ícones perfeitamente */
                    text-align: center;
                }

                .sidebar-menu a:hover {
                    background-color: rgba(255, 255, 255, 0.1);
                    color: white;
                    transform: translateX(5px); /* Efeito sutil de deslizar para a direita */
                }

                .sidebar-menu a.active {
                    background-color: #6366f1; /* Botão ativo ganha a cor do tema */
                    color: white;
                    font-weight: bold;
                    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4); /* Efeito 3D brilhante */
                }

        .sidebar-footer {
            margin-top: auto;
            padding: 20px 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

            .sidebar-footer a {
                padding: 12px 20px;
                display: block;
                color: #cbd5e1;
                text-decoration: none;
                border-radius: 10px;
                transition: all 0.3s ease;
            }

                .sidebar-footer a:hover {
                    background-color: rgba(239, 68, 68, 0.1); /* Tom avermelhado no hover do Sair */
                    color: #fca5a5;
                }

        /* --- CONTEÚDO PRINCIPAL --- */
        .main-content {
            margin-left: 260px; /* Ajustado para o novo tamanho da sidebar */
            flex-grow: 1;
            padding: 30px;
            width: calc(100% - 260px);
        }

        .content-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            margin-bottom: 20px;
        }

            .content-header h4 {
                color: white !important;
                font-weight: bold;
                margin: 0;
                letter-spacing: 0.5px;
            }

        /* Badge de perfil modernizado (Efeito translúcido) */
        .profile-badge {
            position: fixed;
            top: 20px;
            right: 30px;
            background-color: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px); /* Deixa o fundo embaçadinho se suportado */
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            z-index: 9999;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>

    <div class="sidebar">

        <div class="sidebar-header">
            TechFlow Solutions
        </div>

        <div class="user-info">
            <i class="fas fa-user-circle"></i>
            <div>
                <div class="user-name">@ViewBag.UserName</div>
                <div class="user-role">@ViewBag.UserProfile</div>
            </div>
        </div>

        <div class="sidebar-menu">

            <a href="@Url.Action("Dashboard", "Home")" class="@(ViewBag.Title == "Dashboard" ? "active" : "")">
                <i class="fas fa-home mr-2"></i> Dashboard
            </a>

            @if (ViewBag.UserProfile == "Colaborador")
            {
                <a href="@Url.Action("NovoTicket", "Home")" class="@(ViewBag.Title == "Novo Ticket" ? "active" : "")">
                    <i class="fas fa-plus-square mr-2"></i> Novo Ticket
                </a>
                <a href="@Url.Action("MeusTickets", "Home")" class="@(ViewBag.Title == "Meus Tickets" ? "active" : "")">
                    <i class="fas fa-list-alt mr-2"></i> Meus Tickets
                </a>
            }
            else if (ViewBag.UserProfile == "Administrador")
            {
                <a href="@Url.Action("TodosTickets", "Home")" class="@(ViewBag.Title == "Todos os Tickets" ? "active" : "")">
                    <i class="fas fa-clipboard-list mr-2"></i> Todos os Tickets
                </a>
                <a href="@Url.Action("Administracao", "Home")" class="@(ViewBag.Title == "Administração" ? "active" : "")">
                    <i class="fas fa-user-cog mr-2"></i> Administração
                </a>
            }
        </div>

        <div class="sidebar-footer">
            <a href="@Url.Action("Logout", "Home")">
                <i class="fas fa-sign-out-alt mr-2"></i> Sair
            </a>
        </div>
    </div>

    <div class="profile-badge">
        <strong style="opacity: 0.8;">Perfil:</strong> @ViewBag.UserProfile<br>
        <strong style="opacity: 0.8;">Usuário:</strong> @ViewBag.UserName
    </div>

    <div class="main-content">
        <div class="content-header">
            <h4>@ViewBag.Title</h4>
        </div>

        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>