@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - TechFlow Solutions</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <style>
        body {
            /* 🔧 MUDANÇA: Fundo na mesma cor roxa/azul moderna */
            background-color: #6366f1;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            position: relative;
        }

        .login-card {
            background-color: white;
            padding: 40px;
            border-radius: 15px;
            /* Aumentamos a sombra para destacar bem do fundo colorido */
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            max-width: 400px;
            width: 100%;
        }

        .ticket-icon {
            color: white;
            /* Fundo com gradiente moderno (roxo claro para roxo escuro) */
            background: linear-gradient(135deg, #6366f1 0%, #4338ca 100%);
            /* Transforma o quadrado num círculo perfeito */
            border-radius: 50%;
            width: 75px;
            height: 75px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            font-size: 32px; /* Deixa o ícone do ticket maior */
            /* Sombra roxa suave para dar efeito de profundidade (3D) */
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.4);
            /* Borda clara ao redor do círculo para dar contraste */
            border: 4px solid #e0e7ff;
        }

        .demo-info {
            background-color: #f7fafc;
            border-radius: 8px;
            padding: 15px;
            margin-top: 20px;
            text-align: left;
        }

        .alert {
            z-index: 1050;
            position: absolute;
            top: 20px;
            left: 0;
            right: 0;
            max-width: 400px;
            margin: 0 auto;
        }

        /* --- ESTILOS DOS BOTÕES MODERNOS --- */
        .btn-moderno {
            border: none;
            border-radius: 8px; /* Bordas arredondadas */
            padding: 10px 20px;
            font-weight: bold;
            font-size: 16px;
            transition: all 0.3s ease; /* Animação suave */
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none !important;
        }

        /* 🔧 MUDANÇA: Botão Entrar agora é branco com texto roxo para contrastar */
        .btn-moderno-primary {
            background-color: white;
            color: #6366f1 !important;
            border: 2px solid white;
        }

            .btn-moderno-primary:hover {
                background-color: #f1f5f9; /* Fica cinza clarinho no hover */
                transform: translateY(-2px); /* Efeito de pular pra cima */
                box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
                color: #4f46e5 !important;
            }

        /* Botão Criar Conta (Cinza clarinho) */
        .btn-moderno-secondary {
            background-color: #f1f5f9;
            color: #475569 !important;
        }

            .btn-moderno-secondary:hover {
                background-color: #e2e8f0;
                transform: translateY(-2px);
                box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
                color: #334155 !important;
            }
    </style>
</head>
<body>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @ViewBag.ErrorMessage
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="login-card text-center">

        <span class="ticket-icon">
            <i class="fas fa-ticket-alt"></i>
        </span>

        <h2 class="mb-4" style="color: #1e293b;">TechFlow Solutions</h2>

        @using (Html.BeginForm("Login", "Home", FormMethod.Post, new { @class = "form-horizontal" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group text-left">
                <label for="NomeUsuario" style="font-weight: 600; color: #4a5568;">Usuário:</label>
                <input type="text" class="form-control" id="NomeUsuario" name="NomeUsuario" style="border-radius: 8px;" required>
            </div>

            <div class="form-group text-left">
                <label for="Senha" style="font-weight: 600; color: #4a5568;">Senha:</label>
                <input type="password" class="form-control" id="Senha" name="Senha" style="border-radius: 8px;" required>
            </div>

            <div class="form-row mt-4">
                <div class="col">
                    <a href="@Url.Action("Register", "Home")" class="btn-moderno btn-moderno-secondary btn-block">
                        <i class="fas fa-user-plus"></i> Criar Conta
                    </a>
                </div>
                <div class="col">
                    <button type="submit" class="btn-moderno btn-moderno-primary btn-block">
                        <i class="fas fa-arrow-right"></i> Entrar
                    </button>
                </div>
            </div>
        }

        <div class="demo-info small">
            <p class="font-weight-bold mb-1">Usuários cadastrados:</p>
            <p class="mb-0">Colaborador: usuario / senha123</p>
            <p class="mb-0">Administrador: admin / senha123</p>
        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>