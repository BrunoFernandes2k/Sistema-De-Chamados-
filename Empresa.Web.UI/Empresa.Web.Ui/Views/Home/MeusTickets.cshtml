@using Empresa.Web.Ui.DTOs
@model IEnumerable<TicketListDTO>

@{
    ViewBag.Title = "Meus Tickets";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <h2>Meus Tickets</h2>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <a href="@Url.Action("NovoTicket", "Home")" class="btn btn-primary">
            <i class="fas fa-plus"></i> Novo Ticket
        </a>
        <a href="@Url.Action("Dashboard", "Home")" class="btn btn-secondary">
            <i class="fas fa-home"></i> Dashboard
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5><i class="fas fa-list"></i> Seus Tickets</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="thead-light">
                        <tr>
                            <th>ID</th>
                            <th>Assunto</th>
                            <th>Status</th>
                            <th>Prioridade</th>
                            <th>Data Abertura</th>
                            <th>Data Fechamento</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var ticket in Model)
                            {
                                <tr>
                                    <td><strong>#@ticket.Id</strong></td>
                                    <td>@ticket.Assunto</td>
                                    <td>
                                        @if (ticket.Status == "Aberto")
                                        {
                                            <span class="badge badge-success">Aberto</span>
                                        }
                                        else if (ticket.Status == "Em Andamento")
                                        {
                                            <span class="badge badge-warning">Em Andamento</span>
                                        }
                                        else if (ticket.Status == "Concluido")
                                        {
                                            <span class="badge badge-secondary">Concluído</span>
                                        }
                                    </td>
                                    <td>
                                        @if (ticket.Prioridade == "Baixa")
                                        {
                                            <span class="badge badge-info">Baixa</span>
                                        }
                                        else if (ticket.Prioridade == "Media")
                                        {
                                            <span class="badge badge-warning">Média</span>
                                        }
                                        else if (ticket.Prioridade == "Alta")
                                        {
                                            <span class="badge badge-danger">Alta</span>
                                        }
                                    </td>
                                    <td>@ticket.DataAbertura.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (ticket.DataFechamento.HasValue)
                                        {
                                            <span class="text-success">
                                                <i class="fas fa-check-circle"></i>
                                                @ticket.DataFechamento.Value.ToString("dd/MM/yyyy HH:mm")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                <i class="fas fa-clock"></i> Em andamento
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" onclick="deletarTicket(@ticket.Id)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center">Você ainda não tem tickets.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function deletarTicket(id) {
        if (confirm('Tem certeza que deseja deletar este ticket?')) {
            $.ajax({
                url: '@Url.Action("DeletarTicket", "Home")',
                type: 'POST',
                data: { id: id },
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert('Erro: ' + response.message);
                    }
                },
                error: function () {
                    alert('Erro ao deletar ticket.');
                }
            });
        }
    }
</script>

<style>
    .table {
        font-size: 14px;
    }

    .badge {
        font-size: 12px;
        padding: 5px 10px;
    }

    .btn-sm {
        padding: 5px 10px;
    }
</style>