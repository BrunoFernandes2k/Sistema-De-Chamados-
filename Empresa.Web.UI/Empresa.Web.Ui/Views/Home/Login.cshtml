@using System.Web.Mvc.Html
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Sistema de Tickets</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <style>
        body {
            background-color: #2b6cb0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            position: relative;
        }

        .login-card {
            background-color: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            max-width: 400px;
            width: 100%;
        }

        .ticket-icon {
            color: white;
            background-color: #3b82f6;
            border-radius: 5px;
            padding: 10px;
            display: inline-block;
            margin-bottom: 20px;
            font-size: 24px;
        }

        .demo-info {
            background-color: #f7fafc;
            border-radius: 8px;
            padding: 15px;
            margin-top: 20px;
            text-align: left;
        }

        .alert {
            z-index: 1050;
            position: absolute;
            top: 20px;
            left: 0;
            right: 0;
            max-width: 400px;
            margin: 0 auto;
        }
    </style>
</head>
<body>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @ViewBag.ErrorMessage
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="login-card text-center">

        <span class="ticket-icon">
            <i class="fas fa-ticket-alt"></i>
        </span>

        <h2 class="mb-4">Sistema de Tickets</h2>

        @using (Html.BeginForm("Login", "Home", FormMethod.Post, new { @class = "form-horizontal" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group text-left">
                <label for="NomeUsuario">Usuário:</label>
                @* 🔧 CORREÇÃO: Mudou de name="Usuario" para name="NomeUsuario" *@
                <input type="text" class="form-control" id="NomeUsuario" name="NomeUsuario" required>
            </div>

            <div class="form-group text-left">
                <label for="Senha">Senha:</label>
                <input type="password" class="form-control" id="Senha" name="Senha" required>
            </div>

            <div class="form-row mt-4">
                <div class="col">
                    <a href="@Url.Action("Register", "Home")" class="btn btn-secondary btn-block">
                        <i class="fas fa-user-plus"></i> Criar Conta
                    </a>
                </div>
                <div class="col">
                    <button type="submit" class="btn btn-primary btn-block">
                        <i class="fas fa-arrow-right"></i> Entrar
                    </button>
                </div>
            </div>
        }

        <div class="demo-info small">
            <p class="font-weight-bold mb-1">Usuários cadastrados:</p>
            <p class="mb-0">Colaborador: usuario / senha123</p>
            <p class="mb-0">Administrador: admin / senha123</p>
        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>